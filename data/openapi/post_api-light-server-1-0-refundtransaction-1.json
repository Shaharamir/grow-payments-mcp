  "/api/light/server/1.0/getTransactionInfo": {
   "post": {
    "tags": [
     "default"
    ],
    "summary": "Get Transaction Info Copy",
    "requestBody": {
     "content": {
      "multipart/form-data": {
       "schema": {
        "type": "object",
        "properties": {
         "pageCode": {
          "type": "string",
          "description": "Required field - Unique identifier refers to payment mathod",
          "example": "0b7a16e03b25"
         },
         "transactionToken": {
          "type": "string",
          "description": "Required field - transaction identifier",
          "example": "f3095a2579e86d15f5234fba0ee0ef09"
         },
         "transactionId": {
          "type": "integer",
          "description": "Required field - transaction identifier\n",
          "example": "425855"
         }
        }
       }
      }
     }
    },
    "responses": {
     "200": {
      "description": "Successful response",
      "content": {
       "application/json": {}
      }
     }
    }
   }
  }
 },
 "x-readme": {
  "explorer-enabled": true,
  "proxy-enabled": true
 }
